pipeline {
  agent any

  environment {
    SERVER_IP      = '172.31.47.194'              // target EC2 (private or public)
    SSH_CREDENTIAL = 'node-app-key'               // Jenkins credentials ID
    REPO_URL       = 'https://github.com/mahadevatishay/nodejs.git'
    BRANCH         = 'main'
    REMOTE_USER    = 'ubuntu'
    REMOTE_PATH    = '/home/ubuntu/node-app'
    NODE_MAJOR     = '18'                          // choose 16/18/20 as you prefer
  }

  options {
    // fail fast if any command returns non-zero
    timestamps()
  }

  stages {

    stage('Clone Repository') {
      steps {
        checkout([$class: 'GitSCM',
          branches: [[name: "*/${BRANCH}"]],
          userRemoteConfigs: [[url: "${REPO_URL}"]]
        ])
      }
    }

    stage('Upload Files to target-server') {
      steps {
        sshagent([SSH_CREDENTIAL]) {
          sh '''
            set -e
            # Create remote path
            ssh -o StrictHostKeyChecking=no ${REMOTE_USER}@${SERVER_IP} "mkdir -p ${REMOTE_PATH}"

            # Sync workspace to remote (excluding .git and Jenkins-specific dirs)
            rsync -avz --delete \
              --exclude=".git" \
              --exclude=".jenkins" \
              -e "ssh -o StrictHostKeyChecking=no" \
              ./ ${REMOTE_USER}@${SERVER_IP}:${REMOTE_PATH}/
          '''
        }
      }
    }

    stage('Install Node, npm, PM2 & Start App on target') {
      steps {
        sshagent([SSH_CREDENTIAL]) {
          sh '''
            set -e
            ssh -o StrictHostKeyChecking=no ${REMOTE_USER}@${SERVER_IP} bash -lc "
              set -e

              # --- Ensure Node.js and npm are installed (Ubuntu/Debian) ---
              if ! command -v node >/dev/null 2>&1; then
                sudo apt-get update -y
                # Install Node.js ${NODE_MAJOR}.x via nodesource
                curl -fsSL https://deb.nodesource.com/setup_${NODE_MAJOR}.x | sudo -E bash -
                sudo apt-get install -y nodejs
              fi

              # Ensure pm2 is installed globally
              if ! command -v pm2 >/dev/null 2>&1; then
                sudo npm install -g pm2
              fi

              # --- Install app dependencies ---
              cd ${REMOTE_PATH}
              # Prefer clean install if package-lock.json exists
              if [ -f package-lock.json ]; then
                npm ci
              else
                npm install
              fi

              # --- Start (or restart) the app with PM2 ---
              APP_FILE='app.js'  # change if your entry file differs
              if [ ! -f \\"$APP_FILE\\" ]; then
                echo \\"ERROR: $APP_FILE not found in ${REMOTE_PATH}\\" >&2
                exit 1
              fi

              # Start once or restart if already defined
              pm2 start $APP_FILE --name node-app || pm2 restart node-app

              # Save PM2 process list so it auto-restores on reboot
              pm2 save

              # Enable PM2 startup system service (one-time; harmless if re-run)
              pm2 startup systemd -u ${REMOTE_USER} --hp /home/${REMOTE_USER} >/dev/null 2>&1 || true
            "
          '''
        }
      }
    }
  }

  post {
    success {
      echo '✅ Application deployed successfully!'
      echo 'Open: http://<your-public-ip>:3000'
    }
    failure {
      echo '❌ Deployment failed. Check console log for the failing stage.'
    }
  }
}
